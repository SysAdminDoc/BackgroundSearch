{
  "manifest_version": 3,
  "name": "BackgroundSearch",
  "version": "2.1.0",
  "description": "Forces new tabs to open in the background and adds custom search engines to the right-click context menu.",
  "permissions": [
    "tabs",
    "contextMenus",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
